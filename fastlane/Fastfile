opt_out_usage

default_platform(:ios)

platform :ios do
  desc "Download current metadata + screenshots from App Store Connect into /tmp/asc-live"
  lane :download_state do
    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_API_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_filepath: ENV["ASC_KEY_PATH"]
    )

    sh("rm -rf /tmp/asc-live && mkdir -p /tmp/asc-live")

    deliver(
      api_key: api_key,
      run_precheck_before_submit: false,
      metadata_path: "/tmp/asc-live/metadata",
      screenshots_path: "/tmp/asc-live/screenshots",
      skip_binary_upload: true,
      skip_screenshots: false,
      skip_metadata: false,
      force: true
    )
  end

  desc "Upload metadata (and screenshots if present) to App Store Connect"
  lane :upload_metadata do
    api_key = app_store_connect_api_key(
      key_id: ENV["ASC_API_KEY_ID"],
      issuer_id: ENV["ASC_ISSUER_ID"],
      key_filepath: ENV["ASC_KEY_PATH"]
    )

    deliver(
      api_key: api_key,
      run_precheck_before_submit: false,
      skip_binary_upload: true,
      skip_screenshots: false,
      skip_metadata: false,
      force: true,
      submit_for_review: false
    )
  end
end
